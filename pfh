<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Benefits Orientation for New Members</title>
  <style>
    :root {
      --bg: #f8fafc;
      --surface: #ffffff;
      --surface-alt: #f1f5f9;
      --text: #0f172a;
      --muted: #475569;
      --border: #cbd5e1;
      --brand-1: #005a8b;
      --brand-2: #0077b6;
      --brand-3: #00a6a6;
      --brand-4: #e6f4fb;
      --cta: #0b5cab;
      --cta-hover: #084b8a;
      --accent-bg: #fef3c7;
      --accent-border: #fcd34d;
      --accent-text: #78350f;
      --shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
      --radius-lg: 24px;
      --radius-md: 18px;
      --radius-sm: 999px;
      --max-width: 1200px;
    }

    * {
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
      line-height: 1.6;
    }

    a {
      color: var(--brand-2);
      text-decoration: none;
    }

    a:hover,
    a:focus {
      text-decoration: underline;
    }

    .hero {
      background: linear-gradient(135deg, var(--brand-1), var(--brand-2), var(--brand-3));
      color: #fff;
      padding: 64px 24px;
      position: relative;
      overflow: hidden;
    }

    .hero::after {
      content: "";
      position: absolute;
      inset: auto -80px -120px auto;
      width: 320px;
      height: 320px;
      border-radius: 50%;
      background: rgba(255,255,255,0.08);
      filter: blur(8px);
    }

    .container {
      max-width: var(--max-width);
      margin: 0 auto;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 16px;
      padding: 8px 14px;
      border-radius: var(--radius-sm);
      background: rgba(255, 255, 255, 0.16);
      font-size: 14px;
      font-weight: 700;
      letter-spacing: 0.02em;
    }

    h1 {
      margin: 0;
      font-size: clamp(2.25rem, 4vw, 3.5rem);
      line-height: 1.1;
    }

    .hero p {
      max-width: 760px;
      margin-top: 20px;
      font-size: 1.125rem;
      color: rgba(255, 255, 255, 0.92);
    }

    .jump-links-wrap {
      background: rgba(255, 255, 255, 0.96);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(8px);
    }

    .jump-links {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      padding: 18px 24px;
    }

    .jump-links a {
      display: inline-block;
      padding: 10px 16px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--surface);
      color: var(--muted);
      font-size: 0.95rem;
      font-weight: 700;
      box-shadow: 0 2px 10px rgba(15, 23, 42, 0.04);
    }

    .jump-links a:hover,
    .jump-links a:focus {
      color: var(--brand-1);
      text-decoration: none;
      border-color: #7dd3fc;
      background: #f8fcff;
    }

    .cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 24px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 44px;
      padding: 12px 18px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.95rem;
      text-decoration: none;
      border: 1px solid transparent;
      transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    }

    .btn-primary {
      background: #ffffff;
      color: var(--cta);
    }

    .btn-primary:hover,
    .btn-primary:focus {
      background: #f3f9ff;
      color: var(--cta-hover);
      text-decoration: none;
    }

    .btn-secondary {
      background: transparent;
      color: #ffffff;
      border-color: rgba(255,255,255,0.45);
    }

    .btn-secondary:hover,
    .btn-secondary:focus {
      background: rgba(255,255,255,0.10);
      text-decoration: none;
    }

    .layout {
      display: grid;
      grid-template-columns: 280px minmax(0, 1fr);
      gap: 32px;
      padding: 40px 24px 56px;
    }

    .sidebar {
      position: sticky;
      top: 24px;
      align-self: start;
      padding: 22px;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      background: var(--surface);
      box-shadow: var(--shadow);
    }

    .sidebar h2 {
      margin: 0 0 16px;
      font-size: 0.9rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #64748b;
    }

    .sidebar nav a {
      display: block;
      padding: 10px 12px;
      border-radius: 12px;
      color: var(--muted);
      font-size: 0.95rem;
      font-weight: 600;
    }

    .sidebar nav a:hover,
    .sidebar nav a:focus {
      background: var(--surface-alt);
      color: var(--brand-1);
      text-decoration: none;
    }

    .content {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .section-card {
      padding: 28px;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      background: var(--surface);
      box-shadow: var(--shadow);
    }

    .section-card.featured {
      border-color: #b6ddf2;
      background: linear-gradient(180deg, #ffffff, #fbfeff);
    }

    .section-intro-tag {
      display: inline-block;
      margin-bottom: 12px;
      padding: 6px 12px;
      border-radius: 999px;
      background: var(--brand-4);
      color: var(--brand-1);
      font-size: 0.8rem;
      font-weight: 700;
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .section-card h2 {
      margin-top: 0;
      margin-bottom: 12px;
      font-size: 1.85rem;
      line-height: 1.2;
    }

    .section-card p {
      margin: 0 0 14px;
      color: var(--muted);
    }

    .card-grid,
    .bullet-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 16px;
      margin-top: 20px;
    }

    .mini-card,
    .bullet-item {
      padding: 18px;
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      background: var(--surface-alt);
    }

    .mini-card h3 {
      margin: 0 0 8px;
      font-size: 1.05rem;
      line-height: 1.3;
    }

    .mini-card p,
    .bullet-item {
      margin: 0;
      font-size: 0.97rem;
      color: var(--muted);
    }

    .bullet-list {
      list-style: none;
      padding: 0;
      margin: 20px 0 0;
    }

    .note {
      margin-top: 20px;
      padding: 16px 18px;
      border: 1px solid var(--accent-border);
      border-radius: var(--radius-md);
      background: var(--accent-bg);
      color: var(--accent-text);
    }

    .note strong {
      color: #5b3708;
    }

    @media (max-width: 960px) {
      .layout {
        grid-template-columns: 1fr;
      }

      .sidebar {
        position: static;
      }
    }

    @media (max-width: 700px) {
        .hero-visual,
        .timeline,
        .icon-grid,
        .hero-summary-grid,
        .resource-grid {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 960px) {
        .resource-grid {
          grid-template-columns: 1fr 1fr;
        }
      }

      .jump-links {
        padding: 16px 20px;
      }

      .layout {
        padding: 28px 20px 44px;
      }

      .section-card {
        padding: 22px;
      }

      .card-grid,
      .bullet-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
