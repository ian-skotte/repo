  <main class="container layout">
    <style>
      .hero-visual {
        margin-top: 28px;
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 22px;
        align-items: center;
      }

      .hero-illustration,
      .hero-summary {
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 24px;
        padding: 20px;
        backdrop-filter: blur(6px);
      }

      .hero-summary-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
      }

      .hero-stat {
        border-radius: 18px;
        padding: 14px;
        background: rgba(255, 255, 255, 0.12);
      }

      .hero-stat strong {
        display: block;
        font-size: 1.2rem;
        color: #fff;
      }

      .hero-stat span {
        font-size: 0.92rem;
        color: rgba(255,255,255,0.9);
      }

      .icon-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
        margin-top: 20px;
      }

      .icon-card {
        padding: 18px;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: linear-gradient(180deg, #ffffff, #f8fbff);
        text-align: center;
      }

      .icon-card svg {
        filter: drop-shadow(0 4px 10px rgba(15, 23, 42, 0.08));
      }

      .resource-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin-top: 22px;
      }

      .resource-card {
        padding: 20px;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: linear-gradient(180deg, #ffffff, #f8fbff);
      }

      .resource-card h3 {
        margin: 0 0 8px;
        font-size: 1rem;
      }

      .resource-card p {
        margin: 0 0 14px;
        font-size: 0.95rem;
      }

      .resource-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 700;
        color: var(--cta);
      }

      .resource-link::after {
        content: "→";
      }

      .icon-card svg {
        width: 44px;
        height: 44px;
        margin-bottom: 10px;
      }

      .icon-card h3 {
        margin: 0 0 6px;
        font-size: 1rem;
      }

      .icon-card p {
        margin: 0;
        font-size: 0.92rem;
      }

      .comparison-wrap {
        margin-top: 22px;
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
      }

      .comparison-head,
      .comparison-row {
        display: grid;
        grid-template-columns: 1.2fr repeat(4, 1fr);
      }

      .comparison-head > div {
        padding: 16px 14px;
        background: #eaf3ff;
        border-bottom: 1px solid var(--border);
        font-weight: 700;
        font-size: 0.95rem;
      }

      .comparison-row > div {
        padding: 15px 14px;
        border-bottom: 1px solid #e2e8f0;
        border-right: 1px solid #e2e8f0;
        font-size: 0.95rem;
        color: var(--muted);
        background: #fff;
      }

      .comparison-row > div:first-child {
        font-weight: 700;
        color: var(--text);
        background: #f8fafc;
      }

      .comparison-row > div:last-child,
      .comparison-head > div:last-child {
        border-right: none;
      }

      .timeline {
        margin-top: 22px;
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 16px;
      }

      .timeline-step {
        position: relative;
        padding: 18px;
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        background: linear-gradient(180deg, #ffffff, #f8fafc);
      }

      .timeline-step::before {
        content: attr(data-step);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 999px;
        background: var(--brand-2);
        color: #fff;
        font-weight: 700;
        margin-bottom: 12px;
      }

      .timeline-step h3 {
        margin: 0 0 8px;
        font-size: 1rem;
      }

      .timeline-step p {
        margin: 0;
        font-size: 0.94rem;
      }

      @media (max-width: 960px) {
        .hero-visual,
        .timeline,
        .icon-grid {
          grid-template-columns: 1fr 1fr;
        }

        .comparison-head,
        .comparison-row {
          grid-template-columns: 1.2fr repeat(4, minmax(120px, 1fr));
          min-width: 760px;
        }

        .comparison-wrap {
          overflow-x: auto;
        }
      }

      @media (max-width: 700px) {
        .hero-visual,
        .timeline,
        .icon-grid,
        .hero-summary-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
